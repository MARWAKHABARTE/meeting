# ==============================================================================
# Configuration Générale de l'Application
# ==============================================================================
PROJECT_NAME="Meeting AI Platform"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development, staging, production
LOG_LEVEL="INFO"          # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==============================================================================
# Base de Données PostgreSQL
# ==============================================================================
POSTGRES_SERVER="localhost"
POSTGRES_PORT=5432
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="securepassword"
POSTGRES_DB="meeting_ai"

# ==============================================================================
# Redis (Celery & Cache)
# ==============================================================================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=""
CELERY_BROKER_URL=""
CELERY_RESULT_BACKEND=""
CELERY_TASK_SERIALIZER="json"
CELERY_RESULT_SERIALIZER="json"
CELERY_ACCEPT_CONTENT='["json"]'
CELERY_TIMEZONE="UTC"
CELERY_ENABLE_UTC=True

# ==============================================================================
# Stockage S3 / MinIO
# ==============================================================================
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_SECURE=False
MINIO_BUCKET_NAME="meetings"
MINIO_BUCKET="meetings"
MINIO_REGION="us-east-1"

# ==============================================================================
# Authentification Keycloak (OAuth2 / OIDC)
# ==============================================================================
KEYCLOAK_SERVER_URL="http://localhost:8080"
KEYCLOAK_REALM="meeting-ai-realm"
KEYCLOAK_CLIENT_ID="meeting-ai-client"
KEYCLOAK_CLIENT_SECRET="client-secret-placeholder"
KEYCLOAK_ADMIN_USERNAME="admin"
KEYCLOAK_ADMIN_PASSWORD="adminpassword"

# ==============================================================================
# Pipeline IA (Whisper, PyAnnote, NLP, LangChain, Embeddings)
# ==============================================================================
WHISPER_MODEL="base" # options: tiny, base, small, medium, large-v3
WHISPER_DEVICE="cpu"
WHISPER_COMPUTE_TYPE="float32"
PYANNOTE_MODEL="pyannote/speaker-diarization-3.1"
PYANNOTE_AUTH_TOKEN="your_huggingface_pyannote_token_here"
PYANNOTE_TOKEN="your_huggingface_pyannote_token_here"
AI_TEMP_DIRECTORY="temp_ai"
MAX_AUDIO_SIZE_MB=100
SUPPORTED_AUDIO_FORMATS='["mp3", "wav", "m4a", "flac", "ogg", "wma"]'
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
LLM_MODEL="gpt-3.5-turbo"
SPACY_MODEL="fr_core_news_sm"

# ==============================================================================
# Sécurité & CORS
# ==============================================================================
JWT_SECRET_KEY="supersecretjwtkeyforlocaldevelopment"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS="http://localhost:3000,http://localhost:8000"
